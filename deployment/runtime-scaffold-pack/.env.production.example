# Core runtime
APP_ENV=production
DOMAIN=YOUR-DOMAIN.com
BASE_URL=https://YOUR-DOMAIN.com
OPENAI_API_KEY=
JOB_SIGNING_SECRET=

# Service ports
PORT=8080

# Persistence
POSTGRES_URL=postgres://postgres:YOUR_STRONG_DB_PASSWORD@db:5432/xrp_hbar_apex
