# Core runtime
APP_ENV=production
DOMAIN=YOUR-DOMAIN.com
BASE_URL=https://YOUR-DOMAIN.com
OPENAI_API_KEY=
JOB_SIGNING_SECRET=

# Service ports
PORT=8080

# Persistence
POSTGRES_URL=postgres://postgres:YOUR_STRONG_DB_PASSWORD@db:5432/xrp_hbar_apex
POSTGRES_PASSWORD=YOUR_STRONG_DB_PASSWORD
REDIS_URL=redis://redis:6379/0

# XRP/HBAR module namespace
XRP_HBAR_APEX_ENV=production
XRP_HBAR_APEX_BASE_URL=https://YOUR-DOMAIN.com

# Optional future integrations
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=

# Gmail newsletter readiness only. Keep real values in the runtime secret store.
# Required before any Gmail-backed live fetch is attempted.
GMAIL_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=your-client-secret
GMAIL_OAUTH_REFRESH_TOKEN=your-refresh-token

# Optional Gmail fetch tuning for the later live-fetch phase.
GMAIL_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token
GMAIL_NEWSLETTER_QUERY=category:primary newer_than:30d
GMAIL_NEWSLETTER_MAX_RESULTS=5

N8N_WEBHOOK_BASE_URL=
N8N_WEBHOOK_SECRET=
