{
    auto_https off
}

(xrp_hbar_apex_proxy) {
    encode gzip zstd

    handle /health {
        reverse_proxy api:8080
    }

    handle /ready {
        reverse_proxy api:8080
    }

    handle /deployment/status {
        reverse_proxy api:8080
    }

    handle_path /xrp-hbar-apex/* {
        reverse_proxy api:8080
    }

    handle {
        reverse_proxy api:8080
    }
}

:80 {
    import xrp_hbar_apex_proxy
}

{$DOMAIN} {
    import xrp_hbar_apex_proxy
}
